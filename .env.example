# ==============================================================================
# TimeReward Nuxt Application Environment Variables
# ==============================================================================

# Supabase Configuration (Required)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-key"
# Service-role / secret key — server-side ONLY (admin clients, scripts, @nuxtjs/supabase serverSupabaseServiceRole)
# Replaces the legacy SUPABASE_SERVICE_ROLE_KEY / SUPABASE_SERVICE_KEY names.
# See: https://supabase.com/blog/jwt-signing-keys
SUPABASE_SECRET_KEY="your-service-role-or-secret-key"

# Stripe Configuration (Required for payments)
# Note: Nuxt requires NUXT_ prefix for server-side runtime config auto-mapping
NUXT_STRIPE_SECRET_KEY="sk_test_..."                       # Stripe secret key (server-side)
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."           # Stripe publishable key (client-side)
NUXT_STRIPE_WEBHOOK_SECRET="whsec_..."                     # Stripe webhook signing secret

# Stripe Subscription Plans (Price IDs from Stripe Dashboard)
# Get these from: Stripe Dashboard > Products > Your Product > Pricing
NUXT_STRIPE_PRICE_ID_MONTHLY="price_..."                   # 1-month subscription price ID
NUXT_STRIPE_PRICE_ID_QUARTERLY="price_..."                 # 4-month subscription price ID (Quarterly in UI)
NUXT_STRIPE_PRICE_ID_YEARLY="price_..."                    # 12-month (yearly) subscription price ID

# App Configuration
NUXT_PUBLIC_APP_URL="http://localhost:4000"         # Must match devServer port in nuxt.config.ts (4000)
NUXT_PUBLIC_APP_ENV="development"                   # Environment: development, staging, production

# Reserved UI flags (optional — set on Vercel test preview; not wired in app yet)
# Safe to omit locally. Uncomment when implementing landing/auth UI toggles.
# NUXT_PUBLIC_SHOW_TEST_USERS="true"                    # Show test-user affordances on landing/auth
# NUXT_PUBLIC_SHOW_PHONE_NUMBER="true"                  # Show phone number on landing/contact
# NUXT_PUBLIC_HIDE_LANDING_PAGE_COUNTERS="true"          # Hide public counter widgets on landing

# Trial Configuration (Optional — local dev)
# TRIAL_DAYS: inactive until registration wires app/config/trial.ts (see discussions/04_12 §2a).
# Live trial length today = user_profiles.trial_end SQL default (30 days) + subscription middleware.
TRIAL_DAYS="1"                                      # Override trial duration (days) when wired
TRIAL_BYPASS="false"                                # Set to "true" to bypass trial checks in development (local npm run dev only)

# Email Confirmation (Optional)
NUXT_SKIP_EMAIL_CONFIRMATION="true"                 # Set to "true" to auto-confirm new user emails (dev only)

# Demo Data (Optional - set both to 'true' for dev/test/demo environments)
ALLOW_DEMO_DATA="true"                              # Allow /api/admin/load-demo-data endpoint (server-side)
NUXT_PUBLIC_ALLOW_DEMO_DATA="true"                  # Show Reset Demo Data button in UI (client-side)

# Registration gating (Optional)
# BOZ23=1: new usernames must contain "boz23" (existing users can still log in)
# BOZ23=0 or unset: normal registration
BOZ23="0"

# Under construction (Optional — set on Vercel Production only)
# UNDER_CONSTRUCTION=1: all pages and API routes show a static "coming soon" page
# UNDER_CONSTRUCTION=0 or unset: normal app (Preview / test.myfocusrewards.com stays unaffected)
UNDER_CONSTRUCTION="0"

# Vercel KV / Upstash Redis (Optional — keepalive ping for free-tier DB; UptimeRobot → GET /api/keepalive)
KV_REST_API_URL="https://....upstash.io"
KV_REST_API_TOKEN="..."

# Email / Resend (Optional — reserved until Resend Phases 1–3 land; see docs/PRD for Resend use.md)
# Channel A (auth mail): paste RESEND_API_KEY as Supabase Custom SMTP password (username literal "resend").
# Channel B (app mail): runtimeConfig reads these when EmailDeliveryService is wired (Phase 3).
RESEND_API_KEY="re_..."                             # Resend API key (SMTP password + HTTP API)
EMAIL_FROM_ADDRESS="support@myfocusrewards.com"     # Option A: root domain From (must be on a Resend-Verified domain)
EMAIL_FROM_NAME="TimeReward"                        # Display name → "TimeReward <support@myfocusrewards.com>"
# Dashboard-only reference (not read by Nuxt) — Supabase Auth → Email → SMTP:
# RESEND_SMTP_HOST=smtp.resend.com
# RESEND_SMTP_PORT=587
# RESEND_SMTP_USERNAME=resend
# RESEND_SMTP_PASSWORD=<same as RESEND_API_KEY>
# EMAIL_AUTOMATION_ENABLED / EMAIL_DISPATCH_INTERVAL_MS — reserved until Phase 4 (queue); leave unset/false

# Cloudflare Turnstile (Optional)
TURNSTILE_SITE_KEY="0x..."                          # Turnstile site key (client-side)
TURNSTILE_SECRET_KEY="0x..."                        # Turnstile secret key (server-side)

# Geocoding (Optional — reserved; set on Vercel; not wired in app yet)
# GEOCODING_API_KEY="..."                           # Geocoding provider API key (server-side)

# ==============================================================================
# AI/Task Master Keys (Optional - for development tooling)
# ==============================================================================
ANTHROPIC_API_KEY="sk-ant-api03-..."                # Claude API key
PERPLEXITY_API_KEY="pplx-..."                       # Perplexity API key
OPENAI_API_KEY="sk-proj-..."                        # OpenAI API key
GOOGLE_API_KEY="your_google_api_key_here"           # Google Gemini API key
