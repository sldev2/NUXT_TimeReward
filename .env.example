# ==============================================================================
# TimeReward Nuxt Application Environment Variables
# ==============================================================================

# Supabase Configuration (Required)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"  # Server-side only, for admin operations
# Note: SUPABASE_SERVICE_KEY is deprecated. Use SUPABASE_SECRET_KEY instead (JWT signing key)
# See: https://supabase.com/blog/jwt-signing-keys
SUPABASE_SECRET_KEY="your-jwt-secret-key"          # JWT signing key for @nuxtjs/supabase module

# Stripe Configuration (Required for payments)
# Note: Nuxt requires NUXT_ prefix for server-side runtime config auto-mapping
NUXT_STRIPE_SECRET_KEY="sk_test_..."                       # Stripe secret key (server-side)
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."           # Stripe publishable key (client-side)
NUXT_STRIPE_WEBHOOK_SECRET="whsec_..."                     # Stripe webhook signing secret

# Stripe Subscription Plans (Price IDs from Stripe Dashboard)
# Get these from: Stripe Dashboard > Products > Your Product > Pricing
NUXT_STRIPE_PRICE_ID_MONTHLY="price_..."                   # 1-month subscription price ID
NUXT_STRIPE_PRICE_ID_SEMIANNUAL="price_..."                # 6-month subscription price ID  
NUXT_STRIPE_PRICE_ID_YEARLY="price_..."                    # 12-month (yearly) subscription price ID
NUXT_STRIPE_PRICE_ID_DEFAULT="price_..."                   # Default price ID (fallback)

# App Configuration
NUXT_PUBLIC_APP_URL="http://localhost:4000"         # App base URL
NUXT_PUBLIC_APP_ENV="development"                   # Environment: development, staging, production

# Trial Configuration (Optional)
TRIAL_DAYS="1"                                      # Override trial duration (days)
TRIAL_BYPASS="false"                                # Set to "true" to bypass trial checks in development

# Email Confirmation (Optional)
NUXT_SKIP_EMAIL_CONFIRMATION="true"                 # Set to "true" to auto-confirm new user emails (dev only)

# Demo Data (Optional - set both to 'true' for dev/test/demo environments)
ALLOW_DEMO_DATA="true"                              # Allow /api/admin/load-demo-data endpoint (server-side)
NUXT_PUBLIC_ALLOW_DEMO_DATA="true"                  # Show Reset Demo Data button in UI (client-side)

# Email (Optional)
RESEND_API_KEY="re_..."                             # Resend API key for transactional email

# Cloudflare Turnstile (Optional)
TURNSTILE_SITE_KEY="0x..."                          # Turnstile site key (client-side)
TURNSTILE_SECRET_KEY="0x..."                        # Turnstile secret key (server-side)

# ==============================================================================
# AI/Task Master Keys (Optional - for development tooling)
# ==============================================================================
ANTHROPIC_API_KEY="sk-ant-api03-..."                # Claude API key
PERPLEXITY_API_KEY="pplx-..."                       # Perplexity API key
OPENAI_API_KEY="sk-proj-..."                        # OpenAI API key
GOOGLE_API_KEY="your_google_api_key_here"           # Google Gemini API key
